{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "$ref": "#/definitions/ControlUnit",
  "definitions": {
    "ControlUnit": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "devices": {
          "type": "array",
          "items": [
            {
              "$ref": "#/definitions/Device"
            }
          ]
        }
      },
      "required": [
        "id",
        "devices"
      ]
    },
    "Device": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "$ref": "#/definitions/DeviceType"
        },
        "functions": {
          "type": "array",
          "items": [
            {
              "$ref": "#/definitions/Function"
            }
          ]
        }
      },
      "required": [
        "id",
        "type"
      ],
      "processing": true
    },
    "DeviceType": {
      "type": "string",
      "enum": [
        "train",
        "turnout"
      ]
    },
    "Function": {
      "type": "string",
      "enum": [
        "move_forward",
        "move_backward",
        "stop",
        "turnout_pos1",
        "turnout_pos2"
      ]
    },
    "Command": {
      "type": "object",
      "properties": {
        "function": {
          "$ref": "#/definitions/Function"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "function"
      ]
    }
  }
}
